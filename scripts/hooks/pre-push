#!/usr/bin/env bash
# Pre-push hook: run the test suite before allowing a push.
# Install via: bash scripts/install-hooks.sh
#
# Skip with: git push --no-verify

echo "[pre-push] running npm test ..."
npm test
status=$?
if [ $status -ne 0 ]; then
  echo "[pre-push] tests failed (exit $status). Push aborted."
  echo "[pre-push] use 'git push --no-verify' to skip."
  exit $status
fi
exit 0
